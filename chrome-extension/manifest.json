{
  "manifest_version": 3,
  "name": "Titiabar Udyog - WhatsApp Receipt Sender",
  "version": "1.0",
  "description": "Auto-pastes receipt image into WhatsApp Web",
  "permissions": ["tabs", "scripting", "clipboardRead"],
  "host_permissions": [
    "https://web.whatsapp.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
